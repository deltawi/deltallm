generator client {
  provider  = "prisma-client-py"
  interface = "asyncio"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model DeltaLLM_SpendLogEvents {
  id                     String   @id @default(uuid())
  request_id             String
  call_type              String
  api_key                String
  user_id                String?
  team_id                String?
  organization_id        String?
  end_user_id            String?
  model                  String
  deployment_model       String?
  provider               String?
  api_base               String?
  spend                  Float
  provider_cost          Float?
  billing_unit           String?
  pricing_tier           String?
  total_tokens           Int      @default(0)
  input_tokens           Int      @default(0)
  output_tokens          Int      @default(0)
  cached_input_tokens    Int      @default(0)
  cached_output_tokens   Int      @default(0)
  input_audio_tokens     Int      @default(0)
  output_audio_tokens    Int      @default(0)
  input_characters       Int      @default(0)
  output_characters      Int      @default(0)
  duration_seconds       Float    @default(0)
  image_count            Int      @default(0)
  rerank_units           Int      @default(0)
  start_time             DateTime
  end_time               DateTime
  latency_ms             Int?
  cache_hit              Boolean  @default(false)
  cache_key              String?
  request_tags           String[]
  unpriced_reason        String?
  pricing_fields_used    Json?
  usage_snapshot         Json?
  metadata               Json?

  @@index([organization_id, start_time], map: "deltallm_spendlog_events_org_time_idx")
  @@index([team_id, start_time], map: "deltallm_spendlog_events_team_time_idx")
  @@index([api_key, start_time], map: "deltallm_spendlog_events_api_key_time_idx")
  @@index([user_id, start_time], map: "deltallm_spendlog_events_user_time_idx")
  @@index([model, start_time], map: "deltallm_spendlog_events_model_time_idx")
  @@index([provider, start_time], map: "deltallm_spendlog_events_provider_time_idx")
  @@index([start_time], map: "deltallm_spendlog_events_start_time_idx")
  @@index([request_tags], type: Gin, map: "deltallm_spendlog_events_request_tags_gin_idx")
  @@map("deltallm_spendlog_events")
}

model DeltaLLM_TeamModelSpendCounter {
  team_id     String
  model       String
  spend       Float    @default(0)
  updated_at  DateTime @updatedAt

  @@id([team_id, model])
  @@index([team_id], map: "deltallm_teammodelspend_team_idx")
  @@map("deltallm_teammodelspend")
}

model DeltaLLM_VerificationToken {
  id                    String   @id @default(uuid())
  token                 String   @unique
  key_name              String?
  user_id               String?
  team_id               String?
  owner_account_id      String?
  owner_service_account_id String?
  models                String[]
  max_budget            Float?
  soft_budget           Float?
  spend                 Float    @default(0)
  budget_duration       String?
  budget_reset_at       DateTime?
  rpm_limit             Int?
  tpm_limit             Int?
  max_parallel_requests Int?
  expires               DateTime?
  permissions           Json?
  metadata              Json?
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  user       DeltaLLM_UserTable? @relation(fields: [user_id], references: [user_id])
  team       DeltaLLM_TeamTable? @relation(fields: [team_id], references: [team_id])
  owner_account DeltaLLM_PlatformAccount? @relation("verificationtoken_account_owner", fields: [owner_account_id], references: [account_id])
  owner_service_account DeltaLLM_ServiceAccount? @relation("verificationtoken_service_account_owner", fields: [owner_service_account_id], references: [service_account_id])
  @@index([token])
  @@index([user_id])
  @@index([team_id])
  @@index([owner_account_id])
  @@index([owner_service_account_id])
  @@index([expires])
  @@map("deltallm_verificationtoken")
}

model DeltaLLM_UserTable {
  user_id         String   @id
  user_email      String?  @unique
  user_role       String   @default("internal_user")
  max_budget      Float?
  soft_budget     Float?
  spend           Float    @default(0)
  budget_duration String?
  budget_reset_at DateTime?
  models          String[]
  tpm_limit       Int?
  rpm_limit       Int?
  team_id         String?
  metadata        Json?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  team DeltaLLM_TeamTable?          @relation(fields: [team_id], references: [team_id])
  keys DeltaLLM_VerificationToken[]

  @@index([team_id])
  @@map("deltallm_usertable")
}

model DeltaLLM_TeamTable {
  team_id          String   @id @default(uuid())
  team_alias       String?
  organization_id  String?
  max_budget       Float?
  soft_budget      Float?
  spend            Float    @default(0)
  budget_duration  String?
  budget_reset_at  DateTime?
  model_max_budget Json?
  tpm_limit        Int?
  rpm_limit        Int?
  models           String[]
  blocked          Boolean  @default(false)
  metadata         Json?
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  members DeltaLLM_UserTable[]
  keys    DeltaLLM_VerificationToken[]
  service_accounts DeltaLLM_ServiceAccount[]

  @@index([organization_id])
  @@map("deltallm_teamtable")
}

model DeltaLLM_ServiceAccount {
  service_account_id    String   @id @default(uuid())
  team_id               String
  name                  String
  description           String?
  is_active             Boolean  @default(true)
  metadata              Json?
  created_by_account_id String?
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  team       DeltaLLM_TeamTable @relation(fields: [team_id], references: [team_id], onDelete: Cascade)
  created_by DeltaLLM_PlatformAccount? @relation("created_service_accounts", fields: [created_by_account_id], references: [account_id], onDelete: SetNull)
  keys       DeltaLLM_VerificationToken[] @relation("verificationtoken_service_account_owner")

  @@unique([team_id, name])
  @@index([team_id])
  @@index([created_by_account_id])
  @@map("deltallm_serviceaccount")
}

model DeltaLLM_OrganizationTable {
  id                String   @id @default(uuid())
  organization_id   String   @unique
  organization_name String?
  audit_content_storage_enabled Boolean @default(false)
  max_budget        Float?
  rpm_limit         Int?
  tpm_limit         Int?
  spend             Float    @default(0)
  budget_duration   String?
  budget_reset_at   DateTime?
  metadata          Json?
  created_at        DateTime @default(now())
  updated_at        DateTime @updatedAt

  @@map("deltallm_organizationtable")
}

model DeltaLLM_AuditEvent {
  event_id       String   @id @default(uuid())
  occurred_at    DateTime @default(now())
  organization_id String?
  actor_type     String?
  actor_id       String?
  api_key        String?
  action         String
  resource_type  String?
  resource_id    String?
  request_id     String?
  correlation_id String?
  ip             String?
  user_agent     String?
  status         String?
  latency_ms     Int?
  input_tokens   Int?
  output_tokens  Int?
  error_type     String?
  error_code     String?
  metadata       Json?
  content_stored Boolean  @default(false)
  prev_hash      String?
  event_hash     String?

  payloads DeltaLLM_AuditPayload[]

  @@index([occurred_at])
  @@index([organization_id])
  @@index([actor_id])
  @@index([action])
  @@index([request_id])
  @@index([correlation_id])
  @@index([organization_id, occurred_at], map: "deltallm_auditevent_org_occurred_at_idx")
  @@index([action, occurred_at], map: "deltallm_auditevent_action_occurred_at_idx")
  @@index([status, occurred_at], map: "deltallm_auditevent_status_occurred_at_idx")
  @@map("deltallm_auditevent")
}

model DeltaLLM_AuditPayload {
  payload_id      String   @id @default(uuid())
  event_id        String
  kind            String
  storage_mode    String   @default("inline")
  content_json    Json?
  storage_uri     String?
  content_sha256  String?
  size_bytes      Int?
  redacted        Boolean  @default(false)
  created_at      DateTime @default(now())

  event DeltaLLM_AuditEvent @relation(fields: [event_id], references: [event_id], onDelete: Cascade)

  @@index([event_id])
  @@index([kind])
  @@index([created_at])
  @@map("deltallm_auditpayload")
}

model DeltaLLM_PlatformAccount {
  account_id          String   @id @default(uuid())
  email               String   @unique
  password_hash       String?
  role                String   @default("org_user")
  is_active           Boolean  @default(true)
  force_password_change Boolean @default(false)
  mfa_enabled         Boolean  @default(false)
  mfa_secret          String?
  mfa_pending_secret  String?
  metadata            Json?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  last_login_at       DateTime?

  sessions            DeltaLLM_PlatformSession[]
  identities          DeltaLLM_PlatformIdentity[]
  organization_memberships DeltaLLM_OrganizationMembership[]
  team_memberships    DeltaLLM_TeamMembership[]
  owned_keys          DeltaLLM_VerificationToken[] @relation("verificationtoken_account_owner")
  created_service_accounts DeltaLLM_ServiceAccount[] @relation("created_service_accounts")

  @@map("deltallm_platformaccount")
}

model DeltaLLM_PlatformSession {
  session_id          String   @id @default(uuid())
  account_id          String
  session_token_hash  String   @unique
  mfa_verified        Boolean  @default(false)
  expires_at          DateTime
  revoked_at          DateTime?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt
  last_seen_at        DateTime @default(now())

  account DeltaLLM_PlatformAccount @relation(fields: [account_id], references: [account_id], onDelete: Cascade)

  @@index([account_id])
  @@index([expires_at])
  @@map("deltallm_platformsession")
}

model DeltaLLM_PlatformIdentity {
  identity_id         String   @id @default(uuid())
  account_id          String
  provider            String
  subject             String
  email               String?
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  account DeltaLLM_PlatformAccount @relation(fields: [account_id], references: [account_id], onDelete: Cascade)

  @@unique([provider, subject])
  @@index([account_id])
  @@map("deltallm_platformidentity")
}

model DeltaLLM_OrganizationMembership {
  membership_id       String   @id @default(uuid())
  account_id          String
  organization_id     String
  role                String   @default("org_member")
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  account DeltaLLM_PlatformAccount @relation(fields: [account_id], references: [account_id], onDelete: Cascade)

  @@unique([account_id, organization_id])
  @@index([organization_id])
  @@map("deltallm_organizationmembership")
}

model DeltaLLM_TeamMembership {
  membership_id       String   @id @default(uuid())
  account_id          String
  team_id             String
  role                String   @default("team_viewer")
  created_at          DateTime @default(now())
  updated_at          DateTime @updatedAt

  account DeltaLLM_PlatformAccount @relation(fields: [account_id], references: [account_id], onDelete: Cascade)

  @@unique([account_id, team_id])
  @@index([team_id])
  @@map("deltallm_teammembership")
}

model DeltaLLM_Config {
  config_name  String   @id
  config_value String
  updated_by   String?
  updated_at   DateTime @default(now())

  @@map("deltallm_config")
}

model DeltaLLM_ModelDeployment {
  deployment_id   String   @id
  model_name      String
  deltallm_params Json
  model_info      Json?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  route_group_members DeltaLLM_RouteGroupMember[]

  @@index([model_name])
  @@map("deltallm_modeldeployment")
}

model DeltaLLM_RouteGroup {
  route_group_id String   @id @default(uuid())
  group_key      String   @unique
  name           String?
  mode           String   @default("chat")
  routing_strategy String?
  enabled        Boolean  @default(true)
  metadata       Json?
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  members  DeltaLLM_RouteGroupMember[]
  policies DeltaLLM_RoutePolicy[]
  bindings DeltaLLM_RouteGroupBinding[]

  @@index([enabled])
  @@map("deltallm_routegroup")
}

model DeltaLLM_RouteGroupBinding {
  route_group_binding_id String   @id @default(uuid())
  route_group_id         String
  scope_type             String
  scope_id               String
  enabled                Boolean  @default(true)
  metadata               Json?
  created_at             DateTime @default(now())
  updated_at             DateTime @updatedAt

  group DeltaLLM_RouteGroup @relation(fields: [route_group_id], references: [route_group_id], onDelete: Cascade)

  @@unique([route_group_id, scope_type, scope_id], map: "deltallm_routegroupbinding_scope_target_key")
  @@index([scope_type, scope_id, enabled], map: "deltallm_routegroupbinding_scope_idx")
  @@index([route_group_id], map: "deltallm_routegroupbinding_group_idx")
  @@map("deltallm_routegroupbinding")
}

model DeltaLLM_CallableTargetBinding {
  callable_target_binding_id String   @id @default(uuid())
  callable_key               String
  scope_type                 String
  scope_id                   String
  enabled                    Boolean  @default(true)
  metadata                   Json?
  created_at                 DateTime @default(now())
  updated_at                 DateTime @updatedAt

  @@unique([callable_key, scope_type, scope_id], map: "deltallm_callabletargetbinding_scope_target_key")
  @@index([scope_type, scope_id, enabled], map: "deltallm_callabletargetbinding_scope_idx")
  @@index([callable_key], map: "deltallm_callabletargetbinding_target_idx")
  @@map("deltallm_callabletargetbinding")
}

model DeltaLLM_CallableTargetScopePolicy {
  callable_target_scope_policy_id String   @id @default(uuid())
  scope_type                      String
  scope_id                        String
  mode                            String   @default("inherit")
  metadata                        Json?
  created_at                      DateTime @default(now())
  updated_at                      DateTime @updatedAt

  @@unique([scope_type, scope_id], map: "deltallm_callabletargetscopepolicy_scope_key")
  @@index([scope_type, scope_id], map: "deltallm_callabletargetscopepolicy_scope_idx")
  @@map("deltallm_callabletargetscopepolicy")
}

model DeltaLLM_MCPServer {
  mcp_server_id                String   @id @default(uuid())
  server_key                   String   @unique
  name                         String
  description                  String?
  owner_scope_type             String   @default("global")
  owner_scope_id               String?
  transport                    String   @default("streamable_http")
  base_url                     String
  enabled                      Boolean  @default(true)
  auth_mode                    String   @default("none")
  auth_config                  Json?
  forwarded_headers_allowlist  String[]
  request_timeout_ms           Int      @default(30000)
  capabilities_json            Json?
  capabilities_etag            String?
  capabilities_fetched_at      DateTime?
  last_health_status           String?
  last_health_error            String?
  last_health_at               DateTime?
  last_health_latency_ms       Int?
  metadata                     Json?
  created_by_account_id        String?
  created_at                   DateTime @default(now())
  updated_at                   DateTime @updatedAt

  bindings     DeltaLLM_MCPServerBinding[]
  tool_policies DeltaLLM_MCPToolPolicy[]
  approval_requests DeltaLLM_MCPApprovalRequest[]

  @@index([enabled], map: "deltallm_mcpserver_enabled_idx")
  @@index([created_at], map: "deltallm_mcpserver_created_at_idx")
  @@index([owner_scope_type, owner_scope_id], map: "deltallm_mcpserver_owner_scope_idx")
  @@map("deltallm_mcpserver")
}

model DeltaLLM_MCPServerBinding {
  mcp_binding_id  String   @id @default(uuid())
  mcp_server_id   String
  scope_type      String
  scope_id        String
  enabled         Boolean  @default(true)
  tool_allowlist  String[]
  metadata        Json?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  server DeltaLLM_MCPServer @relation(fields: [mcp_server_id], references: [mcp_server_id], onDelete: Cascade)

  @@unique([mcp_server_id, scope_type, scope_id], map: "deltallm_mcpbinding_server_scope_key")
  @@index([scope_type, scope_id, enabled], map: "deltallm_mcpbinding_scope_idx")
  @@index([mcp_server_id], map: "deltallm_mcpbinding_server_idx")
  @@map("deltallm_mcpbinding")
}

model DeltaLLM_MCPToolPolicy {
  mcp_tool_policy_id       String   @id @default(uuid())
  mcp_server_id            String
  tool_name                String
  scope_type               String
  scope_id                 String
  enabled                  Boolean  @default(true)
  require_approval         String?
  max_rpm                  Int?
  max_concurrency          Int?
  result_cache_ttl_seconds Int?
  metadata                 Json?
  created_at               DateTime @default(now())
  updated_at               DateTime @updatedAt

  server DeltaLLM_MCPServer @relation(fields: [mcp_server_id], references: [mcp_server_id], onDelete: Cascade)

  @@unique([mcp_server_id, tool_name, scope_type, scope_id], map: "deltallm_mcptoolpolicy_server_tool_scope_key")
  @@index([mcp_server_id, tool_name], map: "deltallm_mcptoolpolicy_server_tool_idx")
  @@index([scope_type, scope_id, enabled], map: "deltallm_mcptoolpolicy_scope_idx")
  @@map("deltallm_mcptoolpolicy")
}

model DeltaLLM_MCPApprovalRequest {
  mcp_approval_request_id String   @id @default(uuid())
  mcp_server_id           String
  tool_name               String
  scope_type              String
  scope_id                String
  status                  String   @default("pending")
  request_fingerprint     String
  requested_by_api_key    String?
  requested_by_user       String?
  organization_id         String?
  request_id              String?
  correlation_id          String?
  arguments_json          Json
  decision_comment        String?
  decided_by_account_id   String?
  decided_at              DateTime?
  expires_at              DateTime?
  metadata                Json?
  created_at              DateTime @default(now())
  updated_at              DateTime @updatedAt

  server DeltaLLM_MCPServer @relation(fields: [mcp_server_id], references: [mcp_server_id], onDelete: Cascade)

  @@index([mcp_server_id, status, created_at], map: "deltallm_mcpapproval_server_status_created_idx")
  @@index([status, created_at], map: "deltallm_mcpapproval_status_created_idx")
  @@index([request_fingerprint], map: "deltallm_mcpapproval_fingerprint_idx")
  @@map("deltallm_mcpapprovalrequest")
}

model DeltaLLM_PromptTemplate {
  prompt_template_id String   @id @default(uuid())
  template_key       String   @unique
  name               String
  description        String?
  owner_scope        String?
  metadata           Json?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  versions DeltaLLM_PromptVersion[]
  labels   DeltaLLM_PromptLabel[]
  bindings DeltaLLM_PromptBinding[]

  @@index([created_at], map: "deltallm_prompttemplate_created_at_idx")
  @@map("deltallm_prompttemplate")
}

model DeltaLLM_PromptVersion {
  prompt_version_id  String   @id @default(uuid())
  prompt_template_id String
  version            Int
  status             String   @default("draft")
  template_body      Json
  variables_schema   Json?
  model_hints        Json?
  route_preferences  Json?
  published_at       DateTime?
  published_by       String?
  archived_at        DateTime?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  template DeltaLLM_PromptTemplate @relation(fields: [prompt_template_id], references: [prompt_template_id], onDelete: Cascade)
  labels   DeltaLLM_PromptLabel[]

  @@unique([prompt_template_id, version], map: "deltallm_promptversion_template_version_key")
  @@index([prompt_template_id, status], map: "deltallm_promptversion_template_status_idx")
  @@map("deltallm_promptversion")
}

model DeltaLLM_PromptLabel {
  prompt_label_id    String   @id @default(uuid())
  prompt_template_id String
  label              String
  prompt_version_id  String
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  template DeltaLLM_PromptTemplate @relation(fields: [prompt_template_id], references: [prompt_template_id], onDelete: Cascade)
  version  DeltaLLM_PromptVersion  @relation(fields: [prompt_version_id], references: [prompt_version_id], onDelete: Cascade)

  @@unique([prompt_template_id, label], map: "deltallm_promptlabel_template_label_key")
  @@index([prompt_version_id], map: "deltallm_promptlabel_version_idx")
  @@map("deltallm_promptlabel")
}

model DeltaLLM_PromptBinding {
  prompt_binding_id  String   @id @default(uuid())
  scope_type         String
  scope_id           String
  prompt_template_id String
  label              String
  priority           Int      @default(100)
  enabled            Boolean  @default(true)
  metadata           Json?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  template DeltaLLM_PromptTemplate @relation(fields: [prompt_template_id], references: [prompt_template_id], onDelete: Cascade)

  @@index([scope_type, scope_id, enabled, priority], map: "deltallm_promptbinding_scope_idx")
  @@index([prompt_template_id], map: "deltallm_promptbinding_template_idx")
  @@unique([scope_type, scope_id, prompt_template_id, label], map: "deltallm_promptbinding_scope_target_key")
  @@map("deltallm_promptbinding")
}

model DeltaLLM_PromptRenderLog {
  prompt_render_log_id String   @id @default(uuid())
  request_id           String?
  api_key              String?
  user_id              String?
  team_id              String?
  organization_id      String?
  route_group_key      String?
  model                String?
  prompt_template_id   String?
  prompt_version_id    String?
  prompt_key           String?
  label                String?
  status               String
  latency_ms           Int?
  error_code           String?
  error_message        String?
  variables            Json?
  metadata             Json?
  created_at           DateTime @default(now())

  @@index([created_at], map: "deltallm_promptrenderlog_created_at_idx")
  @@index([prompt_key, label, created_at], map: "deltallm_promptrenderlog_prompt_lookup_idx")
  @@index([request_id], map: "deltallm_promptrenderlog_request_idx")
  @@map("deltallm_promptrenderlog")
}

model DeltaLLM_RouteGroupMember {
  membership_id   String   @id @default(uuid())
  route_group_id  String
  deployment_id   String
  enabled         Boolean  @default(true)
  weight          Int?
  priority        Int?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  route_group DeltaLLM_RouteGroup @relation(fields: [route_group_id], references: [route_group_id], onDelete: Cascade)
  deployment  DeltaLLM_ModelDeployment @relation(fields: [deployment_id], references: [deployment_id], onDelete: Cascade)

  @@unique([route_group_id, deployment_id], map: "deltallm_routegroupmember_route_group_id_deployment_id_key")
  @@index([deployment_id], map: "deltallm_routegroupmember_deployment_id_idx")
  @@map("deltallm_routegroupmember")
}

model DeltaLLM_RoutePolicy {
  route_policy_id String   @id @default(uuid())
  route_group_id  String
  version         Int
  status          String   @default("draft")
  policy_json     Json
  published_at    DateTime?
  published_by    String?
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  route_group DeltaLLM_RouteGroup @relation(fields: [route_group_id], references: [route_group_id], onDelete: Cascade)

  @@unique([route_group_id, version], map: "deltallm_routepolicy_route_group_id_version_key")
  @@index([route_group_id, status], map: "deltallm_routepolicy_group_status_idx")
  @@map("deltallm_routepolicy")
}

model DeltaLLM_BatchFile {
  file_id             String   @id @default(uuid())
  purpose             String
  filename            String
  bytes               Int
  status              String   @default("processed")
  storage_backend     String   @default("local")
  storage_key         String
  checksum            String?
  created_by_api_key  String?
  created_by_user_id  String?
  created_by_team_id  String?
  created_at          DateTime @default(now())
  expires_at          DateTime?

  input_jobs          DeltaLLM_BatchJob[] @relation("BatchInputFile")
  output_jobs         DeltaLLM_BatchJob[] @relation("BatchOutputFile")
  error_jobs          DeltaLLM_BatchJob[] @relation("BatchErrorFile")

  @@index([purpose])
  @@index([created_at])
  @@index([expires_at])
  @@map("deltallm_batch_file")
}

model DeltaLLM_BatchJob {
  batch_id                 String   @id @default(uuid())
  endpoint                 String
  status                   String
  execution_mode           String   @default("managed_internal")
  input_file_id            String
  output_file_id           String?
  error_file_id            String?
  model                    String?
  metadata                 Json?
  provider_batch_id        String?
  provider_status          String?
  provider_error           String?
  provider_last_sync_at    DateTime?
  total_items              Int      @default(0)
  in_progress_items        Int      @default(0)
  completed_items          Int      @default(0)
  failed_items             Int      @default(0)
  cancelled_items          Int      @default(0)
  locked_by                String?
  lease_expires_at         DateTime?
  cancel_requested_at      DateTime?
  status_last_updated_at   DateTime @default(now())
  created_by_api_key       String?
  created_by_user_id       String?
  created_by_team_id       String?
  created_at               DateTime @default(now())
  started_at               DateTime?
  completed_at             DateTime?
  expires_at               DateTime?

  input_file DeltaLLM_BatchFile  @relation("BatchInputFile", fields: [input_file_id], references: [file_id])
  output_file DeltaLLM_BatchFile? @relation("BatchOutputFile", fields: [output_file_id], references: [file_id])
  error_file DeltaLLM_BatchFile? @relation("BatchErrorFile", fields: [error_file_id], references: [file_id])
  items DeltaLLM_BatchItem[]

  @@index([status, created_at])
  @@index([lease_expires_at])
  @@index([created_by_api_key, created_at])
  @@index([created_by_team_id, created_at])
  @@index([expires_at])
  @@map("deltallm_batch_job")
}

model DeltaLLM_BatchItem {
  item_id            String   @id @default(uuid())
  batch_id           String
  line_number        Int
  custom_id          String
  status             String
  request_body       Json
  response_body      Json?
  error_body         Json?
  usage              Json?
  provider_cost      Float    @default(0)
  billed_cost        Float    @default(0)
  attempts           Int      @default(0)
  last_error         String?
  locked_by          String?
  lease_expires_at   DateTime?
  created_at         DateTime @default(now())
  started_at         DateTime?
  completed_at       DateTime?

  batch DeltaLLM_BatchJob @relation(fields: [batch_id], references: [batch_id])

  @@unique([batch_id, line_number])
  @@unique([batch_id, custom_id])
  @@index([batch_id, status])
  @@index([lease_expires_at])
  @@map("deltallm_batch_item")
}
