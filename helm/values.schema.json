{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "replicaCount": { "type": "integer", "minimum": 1 },
    "revisionHistoryLimit": { "type": "integer", "minimum": 0 },
    "minReadySeconds": { "type": "integer", "minimum": 0 },
    "image": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string" },
        "tag": { "type": "string" },
        "pullSecrets": { "type": "array" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" },
        "automountServiceAccountToken": { "type": "boolean" }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "annotations": { "type": "object" },
        "labels": { "type": "object" }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": { "type": "array" },
        "tls": { "type": "array" }
      }
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 },
        "targetMemoryUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string" }
          ]
        }
      }
    },
    "env": { "type": "array" },
    "envFrom": { "type": "array" },
    "secret": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "existingSecret": { "type": "string" },
        "keys": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "masterKey": { "type": "string", "minLength": 1 },
            "saltKey": { "type": "string", "minLength": 1 }
          }
        },
        "values": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "masterKey": { "type": "string" },
            "saltKey": { "type": "string" }
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "database": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "url": { "type": "string" },
            "asyncUrl": { "type": "string" },
            "existingSecret": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "name": { "type": "string" },
                "urlKey": { "type": "string" },
                "asyncUrlKey": { "type": "string" }
              }
            }
          }
        },
        "redis": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "url": { "type": "string" },
            "existingSecret": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "name": { "type": "string" },
                "urlKey": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "model_list": { "type": "array" },
        "router_settings": { "type": "object" },
        "deltallm_settings": { "type": "object" },
        "general_settings": { "type": "object" }
      }
    },
    "s3": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "bucket": { "type": "string" },
        "region": { "type": "string" },
        "prefix": { "type": "string" },
        "compression": { "type": "string" },
        "accessKeyId": { "type": "string" },
        "secretAccessKey": { "type": "string" },
        "existingSecret": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "name": { "type": "string" },
            "accessKeyIdKey": { "type": "string" },
            "secretAccessKeyKey": { "type": "string" }
          }
        }
      }
    },
    "prometheus": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "podAnnotations": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "serviceMonitor": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "namespace": { "type": "string" },
            "interval": { "type": "string" },
            "scrapeTimeout": { "type": "string" },
            "labels": { "type": "object" }
          }
        }
      }
    },
    "migrationJob": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "annotations": { "type": "object" },
        "hook": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "deletePolicy": { "type": "string" }
          }
        },
        "backoffLimit": { "type": "integer", "minimum": 0 },
        "activeDeadlineSeconds": { "type": "integer", "minimum": 1 },
        "ttlSecondsAfterFinished": { "type": "integer", "minimum": 0 },
        "command": { "type": "array" },
        "args": { "type": "array" }
      }
    }
  }
}
