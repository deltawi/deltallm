{
  "$schema": "https://json-schema.org/draft-07/schema#",
  "type": "object",
  "additionalProperties": true,
  "properties": {
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "replicaCount": { "type": "integer", "minimum": 1 },
    "revisionHistoryLimit": { "type": "integer", "minimum": 0 },
    "minReadySeconds": { "type": "integer", "minimum": 0 },
    "image": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "pullPolicy": { "type": "string" },
        "tag": { "type": "string" },
        "pullSecrets": { "type": "array" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "create": { "type": "boolean" },
        "name": { "type": "string" },
        "annotations": { "type": "object" },
        "automountServiceAccountToken": { "type": "boolean" }
      }
    },
    "service": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "type": { "type": "string" },
        "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
        "annotations": { "type": "object" },
        "labels": { "type": "object" }
      }
    },
    "ingress": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "className": { "type": "string" },
        "annotations": { "type": "object" },
        "hosts": { "type": "array" },
        "tls": { "type": "array" }
      }
    },
    "autoscaling": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "minReplicas": { "type": "integer", "minimum": 1 },
        "maxReplicas": { "type": "integer", "minimum": 1 },
        "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 },
        "targetMemoryUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "minAvailable": {
          "oneOf": [
            { "type": "integer", "minimum": 0 },
            { "type": "string" }
          ]
        }
      }
    },
    "env": { "type": "array" },
    "envFrom": { "type": "array" },
    "api": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "config": { "type": "object", "additionalProperties": true }
      }
    },
    "batchWorker": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "allowUnsafeLocalStorage": { "type": "boolean" },
        "replicaCount": { "type": "integer", "minimum": 1 },
        "podAnnotations": { "type": "object" },
        "podLabels": { "type": "object" },
        "priorityClassName": { "type": "string" },
        "command": { "type": "array" },
        "args": { "type": "array" },
        "env": { "type": "array" },
        "envFrom": { "type": "array" },
        "extraVolumes": { "type": "array" },
        "extraVolumeMounts": { "type": "array" },
        "service": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "type": { "type": "string" },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 },
            "annotations": { "type": "object" },
            "labels": { "type": "object" }
          }
        },
        "serviceMonitor": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "namespace": { "type": "string" },
            "interval": { "type": "string" },
            "scrapeTimeout": { "type": "string" },
            "labels": { "type": "object" }
          }
        },
        "resources": { "type": "object", "additionalProperties": true },
        "autoscaling": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "minReplicas": { "type": "integer", "minimum": 1 },
            "maxReplicas": { "type": "integer", "minimum": 1 },
            "targetCPUUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 },
            "targetMemoryUtilizationPercentage": { "type": "integer", "minimum": 1, "maximum": 100 }
          }
        },
        "podDisruptionBudget": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "minAvailable": {
              "oneOf": [
                { "type": "integer", "minimum": 0 },
                { "type": "string" }
              ]
            }
          }
        },
        "nodeSelector": { "type": "object" },
        "tolerations": { "type": "array" },
        "affinity": { "type": "object" },
        "topologySpreadConstraints": { "type": "array" },
        "config": { "type": "object", "additionalProperties": true }
      }
    },
    "dependencyWait": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "timeoutSeconds": { "type": "integer", "minimum": 1 },
        "periodSeconds": { "type": "integer", "minimum": 1 }
      }
    },
    "secret": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "existingSecret": { "type": "string" },
        "keys": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "masterKey": { "type": "string", "minLength": 1 },
            "saltKey": { "type": "string", "minLength": 1 }
          }
        },
        "values": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "masterKey": { "type": "string" },
            "saltKey": { "type": "string" }
          }
        }
      }
    },
    "runtime": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "database": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "url": { "type": "string" },
            "existingSecret": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "name": { "type": "string" },
                "urlKey": { "type": "string" }
              }
            }
          }
        },
        "redis": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "url": { "type": "string" },
            "existingSecret": {
              "type": "object",
              "additionalProperties": true,
              "properties": {
                "name": { "type": "string" },
                "urlKey": { "type": "string" }
              }
            }
          }
        }
      }
    },
    "config": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "model_list": { "type": "array" },
        "router_settings": { "type": "object" },
        "deltallm_settings": { "type": "object" },
        "general_settings": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "upstream_http_connect_timeout_seconds": { "type": "number", "exclusiveMinimum": 0 },
            "upstream_http_read_timeout_seconds": { "type": "number", "exclusiveMinimum": 0 },
            "upstream_http_write_timeout_seconds": { "type": "number", "exclusiveMinimum": 0 },
            "upstream_http_pool_timeout_seconds": { "type": "number", "exclusiveMinimum": 0 },
            "upstream_http_max_connections": { "type": "integer", "minimum": 1 },
            "upstream_http_max_keepalive_connections": { "type": "integer", "minimum": 0 },
            "upstream_http_keepalive_expiry_seconds": { "type": "number", "minimum": 0 },
            "embeddings_batch_scheduler_mode": {
              "type": "string",
              "enum": ["fifo_v1", "slice_v1", "model_capacity_v1", "fair_share_v1", "smart_v1"]
            },
            "embeddings_batch_scheduler_shadow_mode": {
              "type": "string",
              "enum": ["none", "fifo_v1", "slice_v1", "model_capacity_v1", "fair_share_v1", "smart_v1"]
            },
            "embeddings_batch_scheduler_shadow_decision_timeout_seconds": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "embeddings_batch_scheduler_shadow_max_pending_decisions": {
              "type": "integer",
              "minimum": 0
            },
            "embeddings_batch_scheduler_enabled": { "type": "boolean" },
            "embeddings_batch_scheduler_shadow_enabled": { "type": "boolean" },
            "embeddings_batch_scheduler_strict_model_homogeneity_enabled": { "type": "boolean" },
            "embeddings_batch_scheduler_default_service_tier": { "type": "string" },
            "embeddings_batch_scheduler_estimator_version": {
              "type": "string",
              "enum": ["v1"]
            },
            "embeddings_batch_scheduler_backfill_enabled": { "type": "boolean" },
            "embeddings_batch_scheduler_backfill_interval_seconds": { "type": "number", "exclusiveMinimum": 0 },
            "embeddings_batch_scheduler_backfill_scan_limit": { "type": "integer", "minimum": 1, "maximum": 5000 },
            "embeddings_batch_stale_lease_sweeper_enabled": { "type": "boolean" },
            "embeddings_batch_stale_lease_sweeper_interval_seconds": { "type": "number", "exclusiveMinimum": 0 },
            "embeddings_batch_stale_lease_sweeper_failure_interval_seconds": { "type": "number", "exclusiveMinimum": 0 },
            "embeddings_batch_stale_lease_sweeper_page_size": { "type": "integer", "minimum": 1, "maximum": 1000 },
            "embeddings_batch_stale_lease_sweeper_max_rows_per_run": { "type": "integer", "minimum": 1, "maximum": 5000 },
            "embeddings_batch_scheduler_claim_mode": {
              "type": "string",
              "enum": ["job_fifo", "work_slice"]
            },
            "embeddings_batch_advisory_lock_mode": {
              "type": "string",
              "enum": ["dual", "canonical"]
            },
            "embeddings_batch_work_claim_max_items": { "type": "integer", "minimum": 0, "maximum": 200 },
            "embeddings_batch_work_claim_max_work_units": { "type": "integer", "minimum": 0 },
            "embeddings_batch_work_claim_min_items_for_microbatch": {
              "type": "integer",
              "minimum": 1,
              "maximum": 200
            },
            "embeddings_batch_model_capacity_enabled": { "type": "boolean" },
            "embeddings_batch_default_model_max_in_flight": { "type": "integer", "minimum": 1 },
            "embeddings_batch_default_model_max_claim_work_units": { "type": "integer", "minimum": 1 },
            "embeddings_batch_model_capacity_fraction": {
              "type": "number",
              "exclusiveMinimum": 0,
              "maximum": 1
            },
            "embeddings_batch_model_capacity_refresh_seconds": { "type": "number", "exclusiveMinimum": 0 },
            "embeddings_batch_model_capacity_fail_open": { "type": "boolean" },
            "embeddings_batch_tenant_fair_share_enabled": { "type": "boolean" },
            "embeddings_batch_scheduler_base_quantum_work_units": { "type": "integer", "minimum": 1 },
            "embeddings_batch_scheduler_max_deficit_multiplier": { "type": "integer", "minimum": 1 },
            "embeddings_batch_tenant_max_in_flight_work_units": { "type": "integer", "minimum": 0 },
            "embeddings_batch_tenant_max_queued_work_units": { "type": "integer", "minimum": 0 },
            "embeddings_batch_scheduler_max_active_flows_per_decision": {
              "type": "integer",
              "minimum": 1,
              "maximum": 1000
            },
            "embeddings_batch_scheduler_max_candidate_jobs_per_flow": {
              "type": "integer",
              "minimum": 1,
              "maximum": 1000
            },
            "embeddings_batch_tenant_scope_preference": { "type": "string" },
            "embeddings_batch_tenant_fair_share_disabled_model_groups": {
              "type": "array",
              "items": { "type": "string" }
            },
            "embeddings_batch_size_aware_scheduling_enabled": { "type": "boolean" },
            "embeddings_batch_aging_seconds_per_work_unit": { "type": "integer", "minimum": 1 },
            "embeddings_batch_max_age_credit_work_units": { "type": "integer", "minimum": 0 },
            "embeddings_batch_min_large_job_claim_interval_seconds": { "type": "integer", "minimum": 0 },
            "embeddings_batch_small_job_fast_lane_enabled": { "type": "boolean" },
            "embeddings_batch_small_job_max_work_units": { "type": "integer", "minimum": 1 },
            "embeddings_batch_finalization_first": { "type": "boolean" }
          }
        }
      }
    },
    "s3": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "bucket": { "type": "string" },
        "region": { "type": "string" },
        "prefix": { "type": "string" },
        "compression": { "type": "string" },
        "accessKeyId": { "type": "string" },
        "secretAccessKey": { "type": "string" },
        "existingSecret": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "name": { "type": "string" },
            "accessKeyIdKey": { "type": "string" },
            "secretAccessKeyKey": { "type": "string" }
          }
        }
      }
    },
    "prometheus": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "podAnnotations": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" }
          }
        },
        "serviceMonitor": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "namespace": { "type": "string" },
            "interval": { "type": "string" },
            "scrapeTimeout": { "type": "string" },
            "labels": { "type": "object" }
          }
        }
      }
    },
    "migrationJob": {
      "type": "object",
      "additionalProperties": true,
      "properties": {
        "enabled": { "type": "boolean" },
        "annotations": { "type": "object" },
        "hook": {
          "type": "object",
          "additionalProperties": true,
          "properties": {
            "enabled": { "type": "boolean" },
            "deletePolicy": { "type": "string" }
          }
        },
        "backoffLimit": { "type": "integer", "minimum": 0 },
        "activeDeadlineSeconds": { "type": "integer", "minimum": 1 },
        "ttlSecondsAfterFinished": { "type": "integer", "minimum": 0 },
        "command": { "type": "array" },
        "args": { "type": "array" }
      }
    }
  }
}
